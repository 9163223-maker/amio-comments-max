{
  "name": "amio-max-event-map",
  "version": "14.12.1",
  "database_target": "postgresql",
  "timezone": "UTC",
  "identity": {
    "primary_user_key": "user_id",
    "primary_session_key": "session_id",
    "session_fallback_keys": ["query_id", "start_param"],
    "channel_key": "channel_id",
    "post_key": "post_id"
  },
  "payload_strategy": {
    "supported_entry_links": ["start", "startapp", "callback", "redirect"],
    "recommended_marketing_keys": [
      "src",
      "med",
      "cmp",
      "cnt",
      "term",
      "crid",
      "adid",
      "plc",
      "inf",
      "ref"
    ],
    "example_compact_payload": "s=maxch;m=post;c=launch_april;t=cr03;p=114;i=wylsa;r=free",
    "example_verbose_payload": {
      "src": "max_channel",
      "med": "post",
      "cmp": "launch_april",
      "cnt": "creative_03",
      "plc": "post_114",
      "inf": "wylsa",
      "ref": "free_comments"
    }
  },
  "default_event_properties": [
    "query_id",
    "platform",
    "client_version",
    "source",
    "medium",
    "campaign",
    "content",
    "term",
    "creative_id",
    "ad_id",
    "placement_id",
    "influencer_id",
    "referral_code",
    "entry_link_type",
    "button_id",
    "placement",
    "poll_id",
    "option_id",
    "comment_id",
    "mode",
    "score",
    "labels"
